    <style>
      /* --- Pokeball Divider System --- */
      .pokeball-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100px;
        height: 100px;
      }

      /* Ground shadow that scales with bounce */
      .pokeball-shadow {
        position: absolute;
        bottom: 2px;
        left: 50%;
        transform: translateX(-50%);
        width: 50px;
        height: 10px;
        background: radial-gradient(ellipse, rgba(0,0,0,0.18) 0%, transparent 70%);
        border-radius: 50%;
        animation: pokeball-shadow 2s cubic-bezier(0.35, 0, 0.25, 1) infinite;
      }

      /* Soft glow ring behind the ball */
      .pokeball-glow {
        position: absolute;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(239, 68, 68, 0.15) 0%, transparent 65%);
        animation: pokeball-glow-pulse 2s ease-in-out infinite;
      }

      /* The ball itself */
      .pokeball-divider {
        position: relative;
        z-index: 2;
        animation: pokeball-bounce 2s cubic-bezier(0.35, 0, 0.25, 1) infinite;
        filter: drop-shadow(0 4px 8px rgba(0,0,0,0.12));
      }

      /* Sparkle particles */
      .pokeball-sparkle {
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #fbbf24;
        z-index: 3;
        opacity: 0;
      }
      .sparkle-1 {
        animation: sparkle-burst 2s ease-out infinite;
        animation-delay: 0.15s;
      }
      .sparkle-2 {
        animation: sparkle-burst-2 2s ease-out infinite;
        animation-delay: 0.25s;
      }
      .sparkle-3 {
        animation: sparkle-burst-3 2s ease-out infinite;
        animation-delay: 0.1s;
      }

      /* Delay variants */
      .delay-300 {
        animation-delay: 0.3s !important;
      }
      .pokeball-wrapper .delay-300.sparkle-1 { animation-delay: 0.45s !important; }
      .pokeball-wrapper .delay-300.sparkle-2 { animation-delay: 0.55s !important; }
      .pokeball-wrapper .delay-300.sparkle-3 { animation-delay: 0.4s !important; }

      /* --- Keyframes --- */
      @keyframes pokeball-bounce {
        0% {
          transform: translateY(0) rotate(0deg) scale(1);
        }
        10% {
          transform: translateY(2px) rotate(0deg) scale(1.03, 0.95);
        }
        30% {
          transform: translateY(-30px) rotate(-12deg) scale(0.95, 1.05);
        }
        50% {
          transform: translateY(0) rotate(0deg) scale(1.05, 0.93);
        }
        58% {
          transform: translateY(0px) rotate(0deg) scale(1, 1);
        }
        70% {
          transform: translateY(-12px) rotate(8deg) scale(0.98, 1.02);
        }
        85% {
          transform: translateY(0) rotate(0deg) scale(1.02, 0.97);
        }
        92% {
          transform: translateY(-3px) rotate(-2deg);
        }
        100% {
          transform: translateY(0) rotate(0deg) scale(1);
        }
      }

      @keyframes pokeball-shadow {
        0%, 100% {
          transform: translateX(-50%) scaleX(1);
          opacity: 0.6;
        }
        10% {
          transform: translateX(-50%) scaleX(1.1);
          opacity: 0.7;
        }
        30% {
          transform: translateX(-50%) scaleX(0.5);
          opacity: 0.25;
        }
        50% {
          transform: translateX(-50%) scaleX(1.15);
          opacity: 0.7;
        }
        70% {
          transform: translateX(-50%) scaleX(0.7);
          opacity: 0.35;
        }
        85% {
          transform: translateX(-50%) scaleX(1.05);
          opacity: 0.6;
        }
      }

      @keyframes pokeball-glow-pulse {
        0%, 100% {
          transform: scale(1);
          opacity: 0.5;
        }
        30% {
          transform: scale(1.3);
          opacity: 0.9;
        }
        50% {
          transform: scale(0.9);
          opacity: 0.4;
        }
        70% {
          transform: scale(1.15);
          opacity: 0.7;
        }
      }

      @keyframes sparkle-burst {
        0%, 8% { opacity: 0; transform: translate(0, 0) scale(0); }
        25% { opacity: 1; transform: translate(-22px, -20px) scale(1); }
        45% { opacity: 0; transform: translate(-30px, -28px) scale(0); }
        100% { opacity: 0; }
      }
      @keyframes sparkle-burst-2 {
        0%, 8% { opacity: 0; transform: translate(0, 0) scale(0); }
        25% { opacity: 1; transform: translate(20px, -24px) scale(1.2); }
        45% { opacity: 0; transform: translate(28px, -32px) scale(0); }
        100% { opacity: 0; }
      }
      @keyframes sparkle-burst-3 {
        0%, 8% { opacity: 0; transform: translate(0, 0) scale(0); }
        25% { opacity: 1; transform: translate(2px, -28px) scale(0.8); }
        45% { opacity: 0; transform: translate(2px, -38px) scale(0); }
        100% { opacity: 0; }
      }
    </style>

    <script>
      // Mobile toggle
      const toggle = document.getElementById("about-nav-toggle");
      const mobileNav = document.getElementById("about-mobile-nav");
      const iconOpen = document.getElementById("about-icon-open");
      const iconClose = document.getElementById("about-icon-close");

      toggle?.addEventListener("click", () => {
        const isOpen = !mobileNav?.classList.contains("hidden");
        mobileNav?.classList.toggle("hidden", isOpen);
        iconOpen?.classList.toggle("hidden", !isOpen);
        iconClose?.classList.toggle("hidden", isOpen);
      });

      window.addEventListener("resize", () => {
        if (window.innerWidth >= 1024) {
          mobileNav?.classList.add("hidden");
          iconOpen?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
        }
      });

      // Close mobile nav on link click
      document.querySelectorAll<HTMLAnchorElement>(".nav-link-mobile").forEach((link) => {
        link.addEventListener("click", () => {
          mobileNav?.classList.add("hidden");
          iconOpen?.classList.remove("hidden");
          iconClose?.classList.add("hidden");
        });
      });

      // Smooth scroll with navbar offset for all anchor links
      const NAVBAR_OFFSET = 72;

      function scrollToSection(hash: string) {
        const id = hash.replace("#", "");
        const target = document.getElementById(id);
        if (!target) return false;

        const top = target.getBoundingClientRect().top + window.scrollY - NAVBAR_OFFSET;
        window.scrollTo({ top, behavior: "smooth" });
        return true;
      }

      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
        link.addEventListener("click", (e) => {
          const hash = link.getAttribute("href");
          if (hash && scrollToSection(hash)) {
            e.preventDefault();
            history.pushState(null, "", hash);
          }
        });
      });

      // Scroll shadow effect
      const navbar = document.getElementById("about-navbar");
      window.addEventListener("scroll", () => {
        if (window.scrollY > 20) {
          navbar?.classList.add("shadow-md");
          navbar?.classList.remove("shadow-sm");
        } else {
          navbar?.classList.remove("shadow-md");
          navbar?.classList.add("shadow-sm");
        }
      }, { passive: true });

      // Active section indicator via IntersectionObserver
      const sectionIds = ["hackathon", "college", "club"];
      const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
      const navIndicators = document.querySelectorAll<HTMLSpanElement>("[data-nav-indicator]");
      const mobileLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link-mobile]");

      function setActive(id: string) {
        navLinks.forEach((link) => {
          const isActive = link.dataset.navLink === id;
          link.classList.toggle("text-red-700", isActive);
          link.classList.toggle("font-bold", isActive);
          link.classList.toggle("bg-red-50/60", isActive);
          link.classList.toggle("text-gray-600", !isActive);
        });
        navIndicators.forEach((ind) => {
          const isActive = ind.dataset.navIndicator === id;
          ind.style.width = isActive ? "60%" : "0";
        });
        mobileLinks.forEach((link) => {
          const isActive = link.dataset.navLinkMobile === id;
          link.classList.toggle("text-red-700", isActive);
          link.classList.toggle("font-bold", isActive);
          link.classList.toggle("bg-red-50/60", isActive);
          link.classList.toggle("text-gray-600", !isActive);
        });
      }

      const observerOptions: IntersectionObserverInit = {
        rootMargin: "-20% 0px -60% 0px",
        threshold: 0,
      };

      const visibleSections = new Map<string, boolean>();

      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          visibleSections.set(entry.target.id, entry.isIntersecting);
        }
        for (const id of sectionIds) {
          if (visibleSections.get(id)) {
            setActive(id);
            return;
          }
        }
      }, observerOptions);

      for (const id of sectionIds) {
        const el = document.getElementById(id);
        if (el) observer.observe(el);
      }
    </script>
  </Fragment>
</BaseLayout>
