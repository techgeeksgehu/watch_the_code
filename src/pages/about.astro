---
import BaseLayout from "@/layout/BaseLayout.astro";
import TopButton from "@/components/pages/index/TopButton.svelte";
import Footer from "@/components/partials/Footer.astro";

const navItems = [
  { label: "The Hackathon", href: "#hackathon" },
  { label: "The College", href: "#college" },
  { label: "The Club", href: "#club" },
];
---

<BaseLayout class="bg-[#cfeffb]">
  <Fragment slot="outside-smooth-scroll">

    <!-- Navbar -->
    <nav id="about-navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#cfeffb]/80 backdrop-blur-lg border-b border-black/5 shadow-sm transition-all duration-300">
      <div class="mx-auto max-w-7xl px-4 py-3 lg:px-8 lg:py-2.5">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <a href="/" class="group flex items-center gap-2 cursor-pointer py-1 font-medium shrink-0">
            <img
              src="/public/logo-landscape.png"
              alt="Watch The Code"
              class="w-52 sm:w-52 h-auto object-contain transition-transform duration-200 group-hover:scale-105"
            />
          </a>

          <!-- Desktop Nav Links -->
          <ul class="hidden lg:flex items-center gap-1 font-comic-para">
            {navItems.map((item) => (
              <li class="relative">
                <a
                  href={item.href}
                  data-nav-link={item.href.slice(1)}
                  class="nav-link relative px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 transition-all duration-200 block"
                >
                  {item.label}
                </a>
                <span
                  data-nav-indicator={item.href.slice(1)}
                  class="nav-indicator absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-0 bg-red-600 rounded-full transition-all duration-300"
                />
              </li>
            ))}
          </ul>

          <!-- Desktop CTA -->
          <div class="hidden lg:flex items-center gap-3">
            <a
              href="/details"
              class="px-5 py-2 text-sm font-bold text-white rounded-xl bg-red-600 shadow-md hover:bg-red-700 hover:shadow-lg active:scale-95 transition-all duration-200 cursor-pointer font-comic-para">
              View Details
            </a>
          </div>

          <!-- Mobile Toggle -->
          <button
            id="about-nav-toggle"
            class="relative w-8 h-8 flex items-center justify-center rounded-lg hover:bg-black/5 transition-colors lg:hidden"
            aria-label="Toggle navigation">
            <svg
              id="about-icon-open"
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-gray-700"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg
              id="about-icon-close"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              class="h-5 w-5 text-gray-700 hidden"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Nav Panel -->
      <div id="about-mobile-nav" class="hidden lg:hidden overflow-hidden">
        <div class="mx-auto max-w-7xl px-4 pb-4 pt-1 border-t border-black/5">
          <ul class="flex flex-col gap-1 mb-3">
            {navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  data-nav-link-mobile={item.href.slice(1)}
                  class="nav-link-mobile block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 transition-all duration-200 font-comic-para"
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>

          <a
            href="/details/"
            class="block w-full px-4 py-2.5 text-sm text-center font-bold text-white rounded-xl bg-red-600 shadow-md hover:bg-red-700 transition-all font-comic-para">
            View Details
          </a>
        </div>
      </div>
    </nav>

    <!-- Spacer to prevent content from hiding behind fixed navbar -->
    <div class="h-14 lg:h-12"></div>

    <!-- =============================== -->
    <!-- HERO: Watch The Code             -->
    <!-- =============================== -->
    <section id="hackathon" class="relative min-h-screen flex items-center justify-center overflow-hidden text-black pt-20">
      <!-- Floating decorations -->
      <div class="hidden md:block absolute top-20 -right-10 -rotate-6 opacity-80">
        <img width="320" src="/public/media/details/pikachu.png" alt="Pikachu" draggable="false" />
      </div>
      <div class="hidden sm:block absolute bottom-16 left-10 rotate-12 opacity-40">
        <img width="120" src="/public/media/details/pokeball-comic.png" alt="" draggable="false" />
      </div>
      <div class="hidden sm:block absolute top-32 left-8 -rotate-20 opacity-40">
        <img width="90" src="/public/media/details/pokeball-comic.png" alt="" draggable="false" />
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <img width="80" class="mx-auto mb-6 sm:w-24" src="/public/media/details/pokemon-text.png" alt="Pokemon text" draggable="false" />
        <h1 class="font-comic-head text-5xl sm:text-6xl md:text-7xl font-extrabold flex flex-wrap justify-center gap-3 sm:gap-5">
          <span class="text-red-800">Watch</span>
          <span class="text-gray-900">The</span>
          <span class="text-blue-800">Code</span>
        </h1>
        <p class="font-comic-head text-lg sm:text-xl mt-4 uppercase text-gray-500 tracking-widest">
          Gotta Code 'Em All
        </p>

        <div class="mt-8 space-y-4 font-comic-para text-sm sm:text-base text-gray-700 max-w-2xl mx-auto leading-relaxed">
          <p>
            <strong class="text-red-700">Watch The Code 2026</strong> is a <em>national-level 24-hour hackathon</em> 
            organised by Graphic Era Hill University, Haldwani Campus. Inspired by the spirit of Pokémon — 
            where trainers push their limits and evolve — this hackathon challenges coders to capture innovative 
            ideas, battle real-world problem statements, and emerge as champions.
          </p>
          <p>
            Over 24 non-stop hours, teams from across the country compete in structured rounds — 
            from idea submissions to live coding battles — putting their skills to the ultimate test. 
            Whether you're a seasoned developer or a first-time hacker, there's a challenge waiting for you.
          </p>
        </div>

        <!-- Stats ribbon -->
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-xl mx-auto">
          <div class="bg-white/60 backdrop-blur rounded-xl border border-red-200 p-4 shadow-sm">
            <p class="font-comic-head text-2xl sm:text-3xl text-red-700 font-bold">24h</p>
            <p class="font-comic-para text-xs text-gray-500 mt-1 uppercase tracking-wide">Non-Stop</p>
          </div>
          <div class="bg-white/60 backdrop-blur rounded-xl border border-blue-200 p-4 shadow-sm">
            <p class="font-comic-head text-2xl sm:text-3xl text-blue-700 font-bold">500+</p>
            <p class="font-comic-para text-xs text-gray-500 mt-1 uppercase tracking-wide">Participants</p>
          </div>
          <div class="bg-white/60 backdrop-blur rounded-xl border border-yellow-300 p-4 shadow-sm">
            <p class="font-comic-head text-2xl sm:text-3xl text-yellow-600 font-bold">₹1L</p>
            <p class="font-comic-para text-xs text-gray-500 mt-1 uppercase tracking-wide">Prize Pool</p>
          </div>
          <div class="bg-white/60 backdrop-blur rounded-xl border border-green-200 p-4 shadow-sm">
            <p class="font-comic-head text-2xl sm:text-3xl text-green-700 font-bold">50+</p>
            <p class="font-comic-para text-xs text-gray-500 mt-1 uppercase tracking-wide">Teams</p>
          </div>
        </div>

        <div class="mt-10 flex flex-wrap gap-4 justify-center">
          <a href="https://gehu.in/hack" target="_blank" rel="noopener noreferrer" class="px-8 py-3 font-comic-para text-sm font-bold text-white rounded-xl bg-red-600 shadow-lg hover:bg-red-700 hover:shadow-xl active:scale-95 transition-all duration-200">
            Register Now
          </a>
          <a href="/details/" class="px-8 py-3 font-comic-para text-sm font-bold text-red-700 rounded-xl border-2 border-red-600 bg-white/50 hover:bg-red-50 active:scale-95 transition-all duration-200">
            Event Details
          </a>
        </div>
      </div>
    </section>

    <!-- =============================== -->
    <!-- Divider: Pokeball                -->
    <!-- =============================== -->
    <div class="flex justify-center py-12">
      <div class="pokeball-wrapper">
        <div class="pokeball-shadow"></div>
        <div class="pokeball-glow"></div>
        <div class="pokeball-sparkle sparkle-1"></div>
        <div class="pokeball-sparkle sparkle-2"></div>
        <div class="pokeball-sparkle sparkle-3"></div>
        <div class="pokeball-divider">
          <img width="70" src="/public/media/details/pokeball-2d.png" alt="" draggable="false" />
        </div>
      </div>
    </div>

    <!-- =============================== -->
    <!-- SECTION 2: GEHU Haldwani        -->
    <!-- =============================== -->
    <section id="college" class="relative min-h-auto py-20 overflow-hidden text-black">
      <div class="hidden md:block absolute -top-8 right-10 opacity-30 rotate-12">
        <img width="180" src="/public/media/details/squirtle-wink.png" alt="" draggable="false" />
      </div>

      <div class="max-w-5xl mx-auto px-6">
        <!-- Header -->
        <div class="text-center mb-12">
          <p class="font-comic-para text-xs uppercase tracking-[0.25em] text-red-500 mb-2">The Arena</p>
          <h2 class="font-comic-head text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900">
            Graphic Era Hill University
          </h2>
          <p class="font-comic-head text-lg sm:text-xl text-blue-700 mt-1 font-semibold">Haldwani Campus</p>
        </div>

        <!-- Content cards -->
        <div class="grid md:grid-cols-2 gap-8">
          <!-- About College -->
          <div class="bg-white/70 backdrop-blur rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" />
                </svg>
              </div>
              <h3 class="font-comic-head text-lg text-gray-900 font-bold">About GEHU</h3>
            </div>
            <div class="space-y-3 font-comic-para text-sm text-gray-600 leading-relaxed">
              <p>
                Graphic Era Hill University (GEHU), Haldwani Campus, is one of the leading educational institutions 
                in Uttarakhand. Nestled at the foothills of the Kumaon hills, the campus provides a vibrant environment 
                for academic excellence and innovation.
              </p>
              <p>
                With state-of-the-art labs, experienced faculty, and a strong focus on practical learning, 
                GEHU has been nurturing the next generation of engineers, entrepreneurs, and tech leaders.
              </p>
            </div>
          </div>

          <!-- Why GEHU -->
          <div class="bg-white/70 backdrop-blur rounded-2xl border border-gray-200 p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <h3 class="font-comic-head text-lg text-gray-900 font-bold">Campus Highlights</h3>
            </div>
            <ul class="space-y-3 font-comic-para text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-0.5">&#9733;</span>
                <span>NAAC accredited university with 20+ years of academic legacy</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-0.5">&#9733;</span>
                <span>Multiple engineering, management, and research programmes</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-0.5">&#9733;</span>
                <span>Strong placement records with top recruiters visiting campus</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-0.5">&#9733;</span>
                <span>Active student clubs fostering innovation, coding, and entrepreneurship</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-0.5">&#9733;</span>
                <span>Modern infrastructure with smart classrooms and high-speed labs</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- =============================== -->
    <!-- Divider: Pokeball                -->
    <!-- =============================== -->
    <div class="flex justify-center py-12">
      <div class="pokeball-wrapper">
        <div class="pokeball-shadow delay-300"></div>
        <div class="pokeball-glow delay-300"></div>
        <div class="pokeball-sparkle sparkle-1 delay-300"></div>
        <div class="pokeball-sparkle sparkle-2 delay-300"></div>
        <div class="pokeball-sparkle sparkle-3 delay-300"></div>
        <div class="pokeball-divider delay-300">
          <img width="70" src="/public/media/details/pokeball-2d.png" alt="" draggable="false" />
        </div>
      </div>
    </div>

    <!-- =============================== -->
    <!-- SECTION 3: Tech Geeks Club       -->
    <!-- =============================== -->
    <section id="club" class="relative min-h-auto py-20 overflow-hidden text-black">
      <div class="hidden md:block absolute top-10 left-6 opacity-25 -rotate-12">
        <img width="160" src="/public/media/details/jigli_puff.png" alt="" draggable="false" />
      </div>
      <div class="hidden sm:block absolute bottom-10 right-8 opacity-30 rotate-6">
        <img width="140" src="/public/media/details/shyduck.png" alt="" draggable="false" />
      </div>

      <div class="max-w-5xl mx-auto px-6">
        <!-- Header -->
        <div class="text-center mb-12">
          <p class="font-comic-para text-xs uppercase tracking-[0.25em] text-blue-500 mb-2">The Trainers</p>
          <h2 class="font-comic-head text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900">
            Tech Geeks
          </h2>
          <p class="font-comic-head text-base sm:text-lg text-gray-500 mt-2">The Official Tech Club of GEHU Haldwani</p>
        </div>

        <!-- About + Mission -->
        <div class="bg-white/70 backdrop-blur rounded-2xl border border-gray-200 p-8 sm:p-10 shadow-sm mb-10">
          <div class="space-y-4 font-comic-para text-sm sm:text-base text-gray-700 leading-relaxed">
            <p>
              <strong class="text-blue-700">Tech Geeks</strong> is the premier technology club of Graphic Era Hill University, 
              Haldwani Campus. Run by students, for students — the club is the beating heart of all things tech on campus. 
              From coding bootcamps and hackathons to workshops on AI, web dev, and competitive programming — 
              Tech Geeks is where ideas evolve into reality.
            </p>
            <p>
              Just like a Pokémon trainer builds their team, Tech Geeks helps students build their skills — 
              one event, one project, one challenge at a time. The club believes in learning by doing 
              and has been the driving force behind multiple national-level tech events.
            </p>
          </div>
        </div>

        <!-- What They Do -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white/70 backdrop-blur rounded-xl border border-red-100 p-6 shadow-sm hover:shadow-md hover:border-red-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-red-50 flex items-center justify-center mb-4 group-hover:bg-red-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Hackathons & Competitions</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Organising and participating in national-level hackathons, coding contests, and tech challenges.
            </p>
          </div>

          <div class="bg-white/70 backdrop-blur rounded-xl border border-blue-100 p-6 shadow-sm hover:shadow-md hover:border-blue-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-4 group-hover:bg-blue-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Workshops & Bootcamps</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Hands-on sessions on web development, AI/ML, cloud computing, open source, and more.
            </p>
          </div>

          <div class="bg-white/70 backdrop-blur rounded-xl border border-yellow-100 p-6 shadow-sm hover:shadow-md hover:border-yellow-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-yellow-50 flex items-center justify-center mb-4 group-hover:bg-yellow-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Community & Mentorship</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Building a strong peer-to-peer learning community with senior mentorship and project guidance.
            </p>
          </div>

          <div class="bg-white/70 backdrop-blur rounded-xl border border-green-100 p-6 shadow-sm hover:shadow-md hover:border-green-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center mb-4 group-hover:bg-green-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Innovation & Projects</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Encouraging open-source contributions, side projects, and real-world problem solving.
            </p>
          </div>

          <div class="bg-white/70 backdrop-blur rounded-xl border border-purple-100 p-6 shadow-sm hover:shadow-md hover:border-purple-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-purple-50 flex items-center justify-center mb-4 group-hover:bg-purple-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Tech Talks & Seminars</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Hosting talks by industry professionals, alumni, and student speakers on trending tech topics.
            </p>
          </div>

          <div class="bg-white/70 backdrop-blur rounded-xl border border-pink-100 p-6 shadow-sm hover:shadow-md hover:border-pink-300 transition-all group">
            <div class="w-12 h-12 rounded-xl bg-pink-50 flex items-center justify-center mb-4 group-hover:bg-pink-100 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h4 class="font-comic-head text-sm font-bold text-gray-900 mb-2">Fun & Networking</h4>
            <p class="font-comic-para text-xs text-gray-500 leading-relaxed">
              Gaming nights and social events that keep the tech community bonded and energized.
            </p>
          </div>
        </div>

        <!-- CTA -->
        <div class="text-center mt-14">
          <p class="font-comic-para text-sm text-gray-500 mb-4">Want to join the squad?</p>
          <div class="flex flex-wrap gap-4 justify-center">
            <a href="https://www.linkedin.com/company/gehu-hackathon" target="_blank" rel="noopener noreferrer" class="px-6 py-3 font-comic-para text-sm font-bold text-white rounded-xl bg-blue-600 shadow-md hover:bg-blue-700 hover:shadow-lg active:scale-95 transition-all duration-200">
              Follow on LinkedIn
            </a>
            <a href="https://instagram.com/gehuhackathon" target="_blank" rel="noopener noreferrer" class="px-6 py-3 font-comic-para text-sm font-bold text-pink-700 rounded-xl border-2 border-pink-400 bg-white/50 hover:bg-pink-50 active:scale-95 transition-all duration-200">
              Follow on Instagram
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- =============================== -->
    <!-- Bottom Pokémon Banner            -->
