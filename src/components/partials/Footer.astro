---
import { Image } from 'astro:assets';
import logoLandscapeImg from '/public/logo-landscape.png';

const quickLinks = [
  { label: "Home", href: "/" },
  { label: "Rounds", href: "#rounds" },
  { label: "Prizes", href: "#prizes" },
  { label: "Rules", href: "#rules" },
  { label: "Challenges", href: "#challenges" },
  { label: "FAQs", href: "#faqs" },
];

const socialLinks = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/company/techgeeksgehu/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.47 2H3.53A1.45 1.45 0 002 3.47v17.06A1.45 1.45 0 003.47 22h17.06A1.45 1.45 0 0022 20.53V3.47A1.45 1.45 0 0020.47 2zM8.09 18.74h-3v-9h3v9zM6.59 8.48a1.56 1.56 0 110-3.12 1.56 1.56 0 010 3.12zM18.91 18.74h-3v-4.83c0-1.21-.43-2-1.52-2A1.65 1.65 0 0012.85 13a2 2 0 00-.1.73v5h-3v-9h3v1.2a3 3 0 012.71-1.5c2 0 3.45 1.29 3.45 4.06v5.25z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/techgeeksgehu/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
  },
  {
    label: "Twitter",
    href: "https://linktr.ee/techgeeksgehu/",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="24" height="24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
  },
];
---

<footer class="relative bg-[#a5e7ff]/50 text-gray-300 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 sm:px-10 pt-10 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

      <!-- Brand Column -->
      <div class="space-y-5">
        <a href="/" class="inline-block">
          <Image
            src={logoLandscapeImg}
            alt="Watch The Code"
            width={320}
            quality={100}
            class="w-80 h-auto object-contain"
          />
        </a>
        <p class="font-comic-para text-sm text-gray-800 leading-relaxed max-w-xs">
          The ultimate challenge for trainers across the region. Level up your
          skills, evolve your projects, and become the champion.
        </p>
      </div>

      <!-- Quick Links Column -->
      <div>
        <h3 class="font-comic-head text-red-600 text-sm tracking-[0.2em] uppercase mb-6">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="group flex items-center gap-2 font-comic-para text-sm text-gray-700 hover:text-black transition-colors duration-200">
                <span class="text-gray-600 group-hover:text-red-600 transition-colors duration-200">
                  &rsaquo;
                </span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social Media Column -->
      <div>
        <h3 class="font-comic-head text-red-600 text-sm tracking-[0.2em] uppercase mb-6">Social Media</h3>
        <div class="flex gap-3 mb-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="w-11 h-11 rounded-lg bg-gray-400/80 border border-gray-400/60 flex items-center justify-center text-white hover:text-red-600 hover:border-gray-400/10 hover:bg-red-600/10 transition-all duration-200">
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
        <p class="font-comic-para text-xs text-gray-500 italic">Follow our journey on the Poke-Network!</p>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-800 mt-10 pt-6">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-3">
        <p class="font-comic-head text-[11px] sm:text-xs text-gray-500 tracking-wider uppercase text-center sm:text-left">
          &copy; 2026 WATCH THE CODE. All rights reserved.
        </p>
        <p class="font-comic-head text-[11px] sm:text-xs text-gray-500 tracking-wider uppercase text-center sm:text-right">
          Built with <span class="text-red-400">&lt;3</span> by the TECH GEEKS
        </p>
      </div>
    </div>
  </div>
</footer>