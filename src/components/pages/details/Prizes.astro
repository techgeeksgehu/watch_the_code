---
import { Image } from "astro:assets";
import secondPrizeImg from "/public/media/details/second-prize.png";
import firstPrizeImg from "/public/media/details/first-prize.png";
import thirdPrizeImg from "/public/media/details/third-prize.png";
import badgeOneImg from "/public/media/details/badge-one.png";
import badgeTwoImg from "/public/media/details/badge-two.png";
import badgeThreeImg from "/public/media/details/badge-three.png";
import badgeFourImg from "/public/media/details/badge-four.png";
import badgeSixImg from "/public/media/details/badge-six.png";

const consolationPrizes = [
  { img: badgeOneImg, alt: "badge one", label: "Boulder Badge" },
  { img: badgeTwoImg, alt: "badge two", label: "Cascade Badge" },
  { img: badgeThreeImg, alt: "badge three", label: "Thunder Badge" },
  { img: badgeFourImg, alt: "badge four", label: "Rainbow Badge" },
  { img: badgeSixImg, alt: "badge six", label: "Soul Badge" },
];
---

<div id="prizes" class="py-20 text-black mt-250 md:mt-120">
  <h1
    class="font-bold font-comic-head text-center mt-10 mb-10 sm:mb-20 lg:mb-34 text-3xl sm:text-4xl">
    League <span class="text-red-800">Rewards</span>
  </h1>

  <!-- Trophy Podium -->
  <div
    class="flex justify-center items-end gap-6 sm:gap-16 lg:gap-40 mt-50 px-4">
    <!-- Second Prize -->
    <div class="mt-6 sm:mt-10 flex flex-col items-center">
      <Image
        width={300}
        quality={100}
        class="w-24 sm:w-32 lg:w-40"
        src={secondPrizeImg}
        alt="rank second trophy"
        draggable="false"
      />
      <h4 class="text-sm sm:text-md text-center font-comic-head mt-4 sm:mt-8"
        >Second Prize</h4
      >
      <p
        class="text-lg sm:text-2xl mt-1 sm:mt-2 font-bold text-center font-comic-head"
        >Rs. 15,000</p
      >
    </div>

    <!-- First Prize (elevated) -->
    <div class="-mt-6 sm:-mt-14 lg:-mt-20 flex flex-col items-center">
      <Image
        width={300}
        quality={100}
        class="w-28 sm:w-36 lg:w-48"
        src={firstPrizeImg}
        alt="rank first trophy"
        draggable="false"
      />
      <h4 class="text-sm sm:text-md text-center font-comic-head mt-4 sm:mt-8"
        >First Prize</h4
      >
      <p
        class="text-lg sm:text-2xl mt-1 sm:mt-2 font-bold text-center font-comic-head"
        >Rs. 50,000</p
      >
    </div>

    <!-- Third Prize -->
    <div class="mt-6 sm:mt-10 flex flex-col items-center">
      <Image
        width={300}
        quality={100}
        class="w-24 sm:w-32 lg:w-40"
        src={thirdPrizeImg}
        alt="rank third trophy"
        draggable="false"
      />
      <h4 class="text-sm sm:text-md text-center font-comic-head mt-4 sm:mt-8"
        >Third Prize</h4
      >
      <p
        class="text-lg sm:text-2xl mt-1 sm:mt-2 font-bold text-center font-comic-head"
        >Rs. 25,000</p
      >
    </div>
  </div>

  <!-- Consolation Prizes -->
  <div class="py-12 sm:py-20 px-4">
    <h3
      class="text-center pb-6 sm:pb-10 font-comic-para font-bold text-base sm:text-lg">
      Consolation Prizes
    </h3>
    <div
      class="flex flex-wrap gap-4 sm:gap-6 lg:gap-8 items-stretch justify-center">
      {
        consolationPrizes.map((badge) => (
          <div class="flex gap-2 flex-col items-center justify-center p-3 sm:p-4 w-28 sm:w-36">
            <Image
              width={60}
              quality={100}
              class="sm:w-18.75"
              src={badge.img}
              alt={badge.alt}
              draggable="false"
            />
            <p class="text-center text-xs sm:text-sm font-medium">
              {badge.label}
            </p>
            <p class="text-xs sm:text-sm text-gray-500 font-bold">Rs. 2,000</p>
          </div>
        ))
      }
    </div>
  </div>
</div>
