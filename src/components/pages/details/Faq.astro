---
import { Image } from 'astro:assets';
import shyduckImg from '/public/media/details/shyduck.png';

const faqs = [
  {
    question: "Who can participate in Watch The Code 2026?",
    answer:
      "Any college student currently enrolled in an undergraduate or postgraduate program can participate. Teams of 4 members are allowed, and cross-college teams are welcome!",
  },
  {
    question: "Is there a registration fee?",
    answer:
      "The registration fee for the final round is ₹250 per participant (₹1000 per team)",
  },
  {
    question: "What happens if a teammate drops out?",
    answer:
      "The Team Leader must inform the organizers immediately. Further action will be taken accordingly, based on the situation and event guidelines.",
  },
  {
    question: "Where is the finale held?",
    answer:
      "The Master's League finale takes place on-campus at Graphic Era Hill University, Haldwani Campus.",
  },
  {
    question: "Will food and accommodation be provided?",
    answer:
      "Yes! Both food and accommodation will be provided for all participants during the hackathon.",
  },
  {
    question: "Is there a Gym Leader we have to defeat?",
    answer:
      "Yes — the judging panel. Prepare your best moves!",
  },
  {
    question: "What if my teammate turns into a Magikarp under pressure?",
    answer: "No worries. With teamwork and support, every Magikarp can become a Gyarados."
  }
];
---

<div id="faq" class="w-full max-w-5xl mx-auto px-4 sm:px-8 mt-20 pb-20 text-black">
  <h2 class="font-comic-head font-bold text-3xl sm:text-4xl text-center mb-2">
    Got <span class="text-red-800">Questions?</span>
  </h2>
  <p class="text-center font-comic-para text-gray-500 text-sm mb-10 sm:mb-14">
    Even Psyduck had questions. We've got answers.
  </p>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
    <!-- FAQ Accordion -->
    <div class="flex flex-col gap-3">
      {
        faqs.map((faq) => (
          <details class="faq-item border-2 border-black rounded-xl">
            <summary class="faq-summary flex justify-between items-center px-5 py-4 cursor-pointer font-comic-head font-bold text-sm sm:text-base bg-white rounded-xl hover:bg-red-50 transition-colors">
              <span>{faq.question}</span>
              <span class="faq-icon ml-3 shrink-0" aria-hidden="true" />
            </summary>
            <div class="px-5 py-4 font-comic-para text-sm text-gray-700 border-t-2 border-black bg-amber-50 rounded-b-xl">
              {faq.answer}
            </div>
          </details>
        ))
      }
    </div>

    <!-- Psyduck mascot -->
    <div class="flex flex-col items-center justify-start pt-4 lg:pt-10 gap-4">
      <div class="relative">
        <Image
          width={260}
          class="sm:w-75 drop-shadow-lg"
          src={shyduckImg}
          alt="Psyduck thinking"
          draggable="false"
        />
        <!-- Speech bubble -->
        <div class="absolute -top-14 -left-4 sm:-left-10 bg-white border-2 border-black rounded-2xl px-4 py-2 max-w-50 shadow-md">
          <p class="font-comic-para text-xs font-bold text-gray-700 leading-snug">
            "Psy... why didn't I read the FAQ first?"
          </p>
          <!-- Bubble tail (outer black border) -->
          <div class="absolute -bottom-2.5 right-8 w-0 h-0 border-l-8 border-r-8 border-t-10 border-l-transparent border-r-transparent border-t-black"></div>
          <!-- Bubble tail (inner white fill) -->
          <div class="absolute -bottom-2 right-8.25 w-0 h-0 border-l-[7px] border-r-[7px] border-t-[9px] border-l-transparent border-r-transparent border-t-white"></div>
        </div>
        
        <p class="text-amber-500 font-bold lowercase absolute top-0 right-0 rotate-20 font-comic-para">"Psy-ay-ay"</p>
      </div>
      <p class="font-comic-para text-xs text-gray-400 italic text-center max-w-55">
        Still confused? Reach out at{" "}
        <span class="text-red-700 font-bold not-italic">techgeeks@gehu.ac.in</span>
      </p>
    </div>
  </div>
</div>

<style>
  /* ── Remove native browser triangle marker ── */
  .faq-item > summary {
    list-style: none;
  }
  .faq-item > summary::-webkit-details-marker {
    display: none;
  }

  /* Flatten bottom radius on open summary so it flows into the answer panel */
  .faq-item[open] > .faq-summary {
    border-radius: 0.75rem 0.75rem 0 0;
  }

  /* ── Animated + / × icon ── */
  .faq-icon {
    position: relative;
    width: 20px;
    height: 20px;
    display: inline-block;
    flex-shrink: 0;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 2.5px;
    background: #991b1b;
    border-radius: 2px;
    transform: translate(-50%, -50%);
    transition: transform 0.25s ease;
  }

  .faq-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-item[open] .faq-icon::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .faq-item[open] .faq-icon::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLDetailsElement>(".faq-item");

  items.forEach((item) => {
    item.addEventListener("toggle", () => {
      if (item.open) {
        items.forEach((other) => {
          if (other !== item && other.open) {
            other.open = false;
          }
        });
      }
    });
  });
</script>