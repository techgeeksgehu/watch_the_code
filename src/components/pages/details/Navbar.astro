---
const navItems = [
  { label: "Rounds", href: "#rounds" },
  { label: "Prizes", href: "#prizes" },
  { label: "Rules", href: "#rules" },
  { label: "Challenges", href: "#challenges" },
  { label: "FAQs", href: "#faqs" },
];
---

<nav id="details-navbar" class="fixed top-0 left-0 right-0 z-50 bg-[#cfeffb]/80 backdrop-blur-lg border-b border-black/5 shadow-sm transition-all duration-300">
  <div class="mx-auto max-w-7xl px-4 py-3 lg:px-8 lg:py-2.5">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="group flex items-center gap-2 cursor-pointer py-1 font-medium shrink-0">
        <img
          src="/public/logo-landscape.png"
          alt="Watch The Code"
          class="w-52 sm:w-52 h-auto object-contain transition-transform duration-200 group-hover:scale-105"
        />
      </a>

      <!-- Desktop Nav Links -->
      <ul class="hidden lg:flex items-center gap-1 font-comic-para">
        {navItems.map((item) => (
          <li class="relative">
            <a
              href={item.href}
              data-nav-link={item.href.slice(1)}
              class="nav-link relative px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 transition-all duration-200 block"
            >
              {item.label}
            </a>
            <span
              data-nav-indicator={item.href.slice(1)}
              class="nav-indicator absolute bottom-0 left-1/2 -translate-x-1/2 h-0.5 w-0 bg-red-600 rounded-full transition-all duration-300"
            />
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="/about/"
          class="px-3 py-2 text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 rounded-lg transition-all duration-200 font-comic-para">
          About
        </a>
        <a
          href="https://gehu.in/hack"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2 text-sm font-bold text-white rounded-xl bg-red-700 shadow-md hover:bg-red-600 hover:shadow-lg active:scale-95 transition-all duration-200 cursor-pointer font-comic-para">
          Register
        </a>
      </div>

      <!-- Mobile Toggle -->
      <button
        id="nav-toggle"
        class="relative w-8 h-8 flex items-center justify-center rounded-lg hover:bg-black/5 transition-colors lg:hidden"
        aria-label="Toggle navigation">
        <svg
          id="icon-open"
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 text-gray-700"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg
          id="icon-close"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          class="h-5 w-5 text-gray-700 hidden"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav Panel -->
  <div id="mobile-nav" class="hidden lg:hidden overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 pb-4 pt-1 border-t border-black/5">
      <ul class="flex flex-col gap-1 mb-3">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              data-nav-link-mobile={item.href.slice(1)}
              class="nav-link-mobile block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 transition-all duration-200 font-comic-para"
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/about/"
            class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-600 hover:text-red-700 hover:bg-red-50/60 transition-all duration-200 font-comic-para"
          >
            About
          </a>
        </li>
      </ul>

      <a
        href="https://gehu.in/hack"
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full px-4 py-2.5 text-sm text-center font-bold text-white rounded-xl bg-red-600 shadow-md hover:bg-red-700 transition-all font-comic-para">
        Register
      </a>
    </div>
  </div>
</nav>

<!-- Spacer to prevent content from hiding behind fixed navbar -->
<div class="h-14 lg:h-12"></div>

<script>
  // Mobile toggle
  const toggle = document.getElementById("nav-toggle");
  const mobileNav = document.getElementById("mobile-nav");
  const iconOpen = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = !mobileNav?.classList.contains("hidden");
    mobileNav?.classList.toggle("hidden", isOpen);
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1024) {
      mobileNav?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    }
  });

  // Close mobile nav on link click
  document.querySelectorAll<HTMLAnchorElement>(".nav-link-mobile").forEach((link) => {
    link.addEventListener("click", () => {
      mobileNav?.classList.add("hidden");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });

  // Smooth scroll with navbar offset for all anchor links
  const NAVBAR_OFFSET = 72; // px — matches navbar height

  function scrollToSection(hash: string) {
    const id = hash.replace("#", "");
    const target = document.getElementById(id);
    if (!target) return false;

    const top = target.getBoundingClientRect().top + window.scrollY - NAVBAR_OFFSET;
    window.scrollTo({ top, behavior: "smooth" });
    return true;
  }

  // Intercept all nav link clicks for precise scrolling
  document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const hash = link.getAttribute("href");
      if (hash && scrollToSection(hash)) {
        e.preventDefault();
        history.pushState(null, "", hash);
      }
    });
  });

  // Scroll shadow effect — add stronger shadow when scrolled
  const navbar = document.getElementById("details-navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("shadow-md");
      navbar?.classList.remove("shadow-sm");
    } else {
      navbar?.classList.remove("shadow-md");
      navbar?.classList.add("shadow-sm");
    }
  }, { passive: true });

  // Active section indicator via IntersectionObserver
  const sectionIds = ["rounds", "prizes", "rules", "challenges", "faqs"];
  const navLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]");
  const navIndicators = document.querySelectorAll<HTMLSpanElement>("[data-nav-indicator]");
  const mobileLinks = document.querySelectorAll<HTMLAnchorElement>("[data-nav-link-mobile]");

  function setActive(id: string) {
    navLinks.forEach((link) => {
      const isActive = link.dataset.navLink === id;
      link.classList.toggle("text-red-700", isActive);
      link.classList.toggle("font-bold", isActive);
      link.classList.toggle("bg-red-50/60", isActive);
      link.classList.toggle("text-gray-600", !isActive);
    });
    navIndicators.forEach((ind) => {
      const isActive = ind.dataset.navIndicator === id;
      ind.style.width = isActive ? "60%" : "0";
    });
    mobileLinks.forEach((link) => {
      const isActive = link.dataset.navLinkMobile === id;
      link.classList.toggle("text-red-700", isActive);
      link.classList.toggle("font-bold", isActive);
      link.classList.toggle("bg-red-50/60", isActive);
      link.classList.toggle("text-gray-600", !isActive);
    });
  }

  const observerOptions: IntersectionObserverInit = {
    rootMargin: "-20% 0px -60% 0px",
    threshold: 0,
  };

  const visibleSections = new Map<string, boolean>();

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      visibleSections.set(entry.target.id, entry.isIntersecting);
    }
    for (const id of sectionIds) {
      if (visibleSections.get(id)) {
        setActive(id);
        return;
      }
    }
  }, observerOptions);

  for (const id of sectionIds) {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  }
</script>
