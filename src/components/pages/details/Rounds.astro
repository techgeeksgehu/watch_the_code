---
import { Image } from 'astro:assets';

import stagesProcessImg from '/public/media/details/stages-process.png';
import mistyShyduckImg from '/public/media/details/misty-shyduck.png';
import brockDudeImg from '/public/media/details/brock-dude.png';
import squirtleWinkImg from '/public/media/details/squirtle-wink.png';
import ashImg from '/public/media/details/ash.png';
import kabutarImg from '/public/media/details/kabutar.png';
---

<div id="rounds" class="relative text-black">
  <h1 class="font-bold font-comic-head text-center mt-10 text-3xl sm:text-4xl">
    The <span class="text-red-800">Journey</span>
  </h1>

  <div class="hidden lg:flex justify-center items-center h-screen opacity-80">
    <Image width={350} src={stagesProcessImg} alt="Stages process" draggable="false" />
  </div>

  <div class="flex flex-col gap-12 px-6 py-10 lg:hidden">

    <!-- Round 1 -->
    <div class="flex flex-col items-center">
      <Image width={220} src={mistyShyduckImg} alt="Misty and Psyduck" draggable="false" />
      <div class="mt-4 text-center">
        <h2 class="font-comic-head font-bold text-lg">Round One: The Indigo League</h2>
        <p class="max-w-sm mx-auto font-comic-para text-xs mt-2 text-center">
          Participants submit their innovative solution ideas and approach for the
          given problem statement for initial evaluation and shortlisting.
        </p>
      </div>
    </div>

    <!-- Round 2 -->
    <div class="flex flex-col items-center">
      <Image width={160} src={brockDudeImg} alt="Brock" draggable="false" />
      <div class="mt-4 text-center">
        <h2 class="font-comic-head font-bold text-lg">Round Two: The Indigo League</h2>
        <p class="max-w-sm mx-auto font-comic-para text-xs mt-2 text-center">
          Shortlisted teams will build and present a working MVP with system
          architecture and GitHub submission, evaluated on implementation quality,
          scalability, and teamwork.
        </p>
      </div>
    </div>

    <!-- Squirtle cameo -->
    <div class="flex flex-col items-center opacity-80">
      <Image width={120} class="rotate-12" src={squirtleWinkImg} alt="Squirtle winking" draggable="false" />
      <p class="font-comic-para font-bold text-xs text-sky-800 mt-1 -rotate-3">"squirtle, squirtle"</p>
    </div>

    <!-- Finale -->
    <div class="flex flex-col items-center">
      <div class="relative">
        <Image width={220} src={ashImg} alt="Ash" draggable="false" />
        <Image
          width={100}
          class="absolute -top-10 -right-8 opacity-80"
          src={kabutarImg}
          alt=""
          draggable="false"
        />
      </div>
      <div class="mt-4 text-center">
        <h2 class="font-comic-head font-bold text-lg">Finale: The Master's League</h2>
        <p class="max-w-sm mx-auto font-comic-para text-xs mt-2 text-center">
          Shortlisted teams will compete on-campus to develop and present
          innovative, real-world solutions to industry-curated problem statements
          before a judging panel.
        </p>
      </div>
    </div>
  </div>

  <!-- Round 1: top-left -->
  <div class="hidden lg:flex absolute top-20 left-20 xl:left-30 items-center flex-col">
    <Image width={260} src={mistyShyduckImg} alt="Misty and Psyduck" draggable="false" />
    <div class="mt-4">
      <h1 class="text-center font-comic-head font-bold">Round One: The Indigo League</h1>
      <p class="max-w-xs xl:max-w-100 text-center font-comic-para text-xs mt-2">
        Participants submit their innovative solution ideas and approach for the
        given problem statement for initial evaluation and shortlisting.
      </p>
    </div>
  </div>

  <!-- Round 2: top-right -->
  <div class="hidden lg:flex absolute top-40 right-10 xl:right-20 items-center flex-col">
    <Image width={160} src={brockDudeImg} alt="Brock" draggable="false" />
    <div class="mt-4">
      <h1 class="text-center font-comic-head font-bold">Round Two: The Indigo League</h1>
      <p class="max-w-xs xl:max-w-100 text-center font-comic-para text-xs mt-2">
        Shortlisted teams will build and present a working MVP with system
        architecture and GitHub submission, evaluated on implementation quality,
        scalability, and teamwork.
      </p>
    </div>
  </div>

  <!-- Squirtle: bottom-left decoration -->
  <div class="hidden lg:block absolute z-0 bottom-40 left-40 xl:left-60 rotate-24">
    <Image width={140} src={squirtleWinkImg} alt="Squirtle winking" draggable="false" />
  </div>
  <div class="hidden lg:block absolute bottom-36 left-32 xl:left-50 rotate-39">
    <p class="font-comic-para font-bold text-xs text-sky-800">"squirtle, squirtle"</p>
  </div>

  <!-- Finale: bottom-right -->
  <div class="hidden lg:flex absolute -bottom-40 right-40 xl:right-60 items-center flex-row-reverse">
    <Image width={240} src={ashImg} alt="Ash" draggable="false" />
    <div class="z-10">
      <h1 class="text-center font-comic-head font-bold">Finale: The Master's League</h1>
      <p class="max-w-xs xl:max-w-100 text-center font-comic-para text-xs mt-2">
        Shortlisted teams will compete on-campus to develop and present
        innovative, real-world solutions to industry-curated problem statements
        before a judging panel.
      </p>
    </div>
    <Image
      width={120}
      class="absolute z-0 bottom-46 right-60 xl:right-75"
      src={kabutarImg}
      alt=""
      draggable="false"
    />
  </div>
</div>