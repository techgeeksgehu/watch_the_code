---
import Image from "@/components/helpers/Image.astro";
import BGImage from "@/assets/images/pages/index/sec 9/bg.png";
---

<section id="section-9" class="relative">
    <Image
        src={BGImage}
        id="section-9-bg"
        alt="Background"
        class="absolute inset-0 w-full h-lvh object-cover z-0"
    />

    <div class="absolute inset-0 w-full h-lvh z-2 pointer-events-none">
        <h2
            class="w-[50%] lg:w-[25%] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-minecraft text-white text-center absolute top-1/4 left-1/2 md:left-1/3 -translate-x-1/2 -translate-y-1/2"
        >
            We watched a boy from small town chase something bigger than
            himself.
        </h2>
        <h2
            class="w-[50%] lg:w-[25%] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-minecraft text-white text-center absolute top-3/4 md:top-1/2 left-1/2 md:left-2/3 -translate-x-1/2 -translate-y-1/2"
        >
            And we watched him fail. Again and again.
        </h2>
    </div>
</section>

<script>
    document.addEventListener(
        "astro:page-load",
        () => {
            gsap.set("#section-9", { opacity: 0, marginTop: "-100vh" });
            gsap.set("#section-9-bg", { scale: 1.2, xPercent: -1 });

            gsap.timeline({
                scrollTrigger: {
                    trigger: "#section-9",
                    start: "top top",
                    end: "+=200% bottom",
                    scrub: true,
                    pin: true,
                },
            })
                .to(
                    "#section-9",
                    { opacity: 1, duration: 0.5, ease: "none" },
                    0,
                )
                .to(
                    "#section-9-bg",
                    { xPercent: 1, duration: 3, ease: "none" },
                    0,
                )
                .to("#section-9 ", { opacity: 0, duration: 0.5, ease: "none" });
        },
        { once: false },
    );
</script>
