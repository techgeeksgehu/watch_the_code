---
import Image from "@/components/helpers/Image.astro";
import BGImage from "@/assets/images/pages/index/sec 11/bg.png";
import FGImage from "@/assets/images/pages/index/sec 11/fg.png";
---

<section id="section-11" class="relative">
    <Image
        src={BGImage}
        id="section-11-bg"
        alt="Background"
        class="absolute inset-0 w-full h-lvh object-cover z-0"
    />
    <Image
        src={FGImage}
        id="section-11-fg"
        alt="Foreground"
        class="absolute inset-0 w-full h-lvh object-cover z-1"
    />

    <div class="absolute inset-0 w-full h-lvh z-2 pointer-events-none">
        <h2
            class="w-[75%] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-minecraft text-black text-center absolute top-1/6 left-1/2 -translate-x-1/2 -translate-y-1/2"
        >
            And then one day we packed our bags too<br />int the hope to find
            the road that<br />leads us to our own<br />Destiny
        </h2>
        <h2
            class="w-[75%] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-minecraft text-white text-center absolute top-5/6 left-1/2 -translate-x-1/2 -translate-y-1/2"
        >
            Some of us took the path not taken<br />while others walked along
            others<br />marching in hope to find<br />Something they call their
            own.
        </h2>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        gsap.set("#section-11", { opacity: 0, marginTop: "-100vh" });
        gsap.timeline({
            scrollTrigger: {
                trigger: "#section-11",
                start: "top top",
                end: "+=200% bottom",
                scrub: true,
                pin: true,
            },
        })
            .to("#section-11", { opacity: 1, duration: 0.5, ease: "none" }, 0)
            .to("#section-11-bg", { scale: 1.1, duration: 3, ease: "none" }, 0)
            .to("#section-11-fg", { scale: 1.3, duration: 3, ease: "none" }, 0)
            .to("#section-11", { opacity: 0, duration: 0.5, ease: "none" });
    });
</script>
