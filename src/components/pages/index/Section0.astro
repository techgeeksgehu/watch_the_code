<section id="section-0" class="relative">
    <div class="absolute h-full w-full flex-center" id="section-0-text-wrapper">
        <h2
            id="section-0-text"
            class="font-minecraft text-white text-center text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        >
        </h2>
    </div>
</section>

<script>
    import { gsap, ScrollTrigger } from "@/lib/gsap";

    document.addEventListener(
        "astro:page-load",
        () => {
            const el = document.getElementById("section-0-text");
            if (!el) return;

            const fullText = "Scroll down...";
            let typed = false;

            gsap.to(el, {
                text: fullText,
                delay: 0.6,
                duration: 1.2,
                ease: "none",
                onComplete() {
                    typed = true;
                },
            });

            ScrollTrigger.create({
                trigger: "#section-0",
                start: "top top",
                end: "bottom center",
                scrub: true,
                pin: true,
                invalidateOnRefresh: true,
                onUpdate(self) {
                    if (!typed) return;
                    const p = self.progress;
                    const remaining = Math.round((1 - p) * fullText.length);
                    el.textContent = fullText.slice(0, remaining);
                },
            });
        },
        { once: false },
    );
</script>
