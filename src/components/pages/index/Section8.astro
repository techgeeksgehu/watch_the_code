---
import Image from "@/components/helpers/Image.astro";
import BGImage from "@/assets/images/pages/index/sec 8/bg.png";
---

<section id="section-8" class="relative">
    <Image
        src={BGImage}
        id="section-8-bg"
        alt="Background"
        class="absolute inset-0 w-full h-lvh object-cover z-0"
        style="object-position: 20% 50%"
    />

    <div class="absolute inset-0 w-full h-lvh z-2 pointer-events-none">
        <h2
            class="w-[50%] sm:text-lg md:text-xl lg:text-2xl xl:text-3xl font-minecraft text-white text-center absolute top-3/4 left-1/2 -translate-x-1/2 -translate-y-1/2"
        >
            Taught us that<br />competition<br />wasn't so cruel
        </h2>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        gsap.set("#section-8", { opacity: 0, marginTop: "-132vh" });
        gsap.set("#section-8-bg", { scale: 1.2, xPercent: -1 });

        gsap.timeline({
            scrollTrigger: {
                trigger: "#section-8",
                start: "top top",
                end: "+=200% bottom",
                scrub: true,
                pin: true,
            },
        })
            .to("#section-8", { opacity: 1, duration: 0.5, ease: "none" }, 0)
            .to("#section-8-bg", { xPercent: 1, duration: 3, ease: "none" }, 0)
            .to("#section-8 ", { opacity: 0, duration: 0.5, ease: "none" });
    });
</script>
