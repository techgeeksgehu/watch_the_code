---
import Image from "@/components/helpers/Image.astro";
import LogoImage from "@/assets/images/logo.png";
import GEHU from "@/assets/images/gehu_hld_mono.svg";
import TechGeeks from "@/assets/images/tech_geeks_mono.svg";
import ExploreButton from "./ExploreButton.svelte";
---

<section id="section-final" class="relative bg-[#1b72d2]">
    <div
        class="absolute h-full w-full flex-center"
        id="section-final-pretext-wrapper"
    >
        <h2
            id="section-final-pretext"
            class="font-minecraft text-white text-center text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        >
        </h2>
    </div>
    <video
        id="section-final-video"
        preload="auto"
        playsinline
        muted
        autoplay
        class="absolute inset-0 h-full w-full object-cover"
        style="object-position: 75% 50%"
    >
        <!-- 480p -->
        <source
            src="/media/wtc/video-480-hevc.mp4"
            media="(max-width: 480px)"
            type=`video/mp4; codecs="hvc1"`
        />
        <source
            src="/media/wtc/video-480-h264.mp4"
            media="(max-width: 480px)"
            type="video/mp4"
        />
        <!-- 720p -->
        <source
            src="/media/wtc/video-720-hevc.mp4"
            media="(min-width: 481px) and (max-width: 1080px)"
            type=`video/mp4; codecs="hvc1"`
        />
        <source
            src="/media/wtc/video-720-h264.mp4"
            media="(min-width: 481px) and (max-width: 1080px)"
            type="video/mp4"
        />
        <!-- 1080p -->
        <source
            src="/media/wtc/video-1080-hevc.mp4"
            media="(min-width: 1081px)"
            type=`video/mp4; codecs="hvc1"`
        />
        <source
            src="/media/wtc/video-1080-h264.mp4"
            media="(min-width: 1081px)"
            type="video/mp4"
        />
    </video>

    <div class="pointer-events-none absolute inset-0 z-10">
        <div
            id="section-final-logo"
            class="absolute top-1/2 left-1/2 md:left-1/3 lg:left-1/4 -translate-x-1/2 -translate-y-1/2"
        >
            <Image
                src={LogoImage}
                alt="Watch The Code Logo"
                class="w-100 xs:w-110 sm:w-115 md:w-120 lg:w-125 xl:w-150 h-auto"
            />
        </div>

        <div
            id="section-final-header"
            class="flex flex-row justify-between p-5"
        >
            <GEHU class="logo w-auto h-8 xs:h-16 sm:h-20 md:h-24 lg:h-28" />
            <TechGeeks
                class="logo w-auto h-8 xs:h-16 sm:h-20 md:h-24 lg:h-28"
            />
        </div>
    </div>

    <div
        class="absolute top-3/4 left-1/2 md:left-1/3 lg:left-1/4 -translate-x-1/2 -translate-y-1/2 z-5"
        id="section-final-cta"
    >
        <ExploreButton client:load />
    </div>
</section>

<script>
    import { loadVideo } from "@/lib/helpers";

    const video = document.getElementById(
        "section-final-video",
    ) as HTMLVideoElement;

    document.addEventListener("astro:page-load", () => {
        gsap.set("#section-final", { opacity: 0, marginTop: "-100vh" });
        gsap.set(video, { opacity: 0 });
        gsap.set("#section-final-logo", { opacity: 0 });
        gsap.set("#section-final-header .logo", { opacity: 0 });
        gsap.set("#section-final-cta", { opacity: 0 });

        const tl = gsap.timeline({
            defaults: { duration: 1 },
            scrollTrigger: {
                trigger: "#section-final",
                start: "top top",
                end: "+=350% top",
                scrub: true,
                pin: true,
                id: "section-final-pin",
            },
        });

        tl.to("#section-final", { opacity: 1, duration: 0.5, ease: "none" }, 0)
            .to("#skip-button", { opacity: 0, duration: 0.5, ease: "none" }, 0)
            .to("#top-button", { opacity: 1, duration: 0.5, ease: "none" }, 0)
            .to(
                "#section-final-pretext",
                { text: "Tech Geeks presents", duration: 1.5, ease: "none" },
                0.1,
            )
            .to(
                "#section-final-pretext-wrapper",
                { opacity: 0, duration: 0.5, ease: "none" },
                2,
            )
            .to(
                video,
                {
                    opacity: 1,
                    duration: 1,
                },
                2,
            )
            .to(
                "#section-final-header .logo",
                {
                    opacity: 1,
                    duration: 1,
                    stagger: 1,
                },
                3,
            )
            .to(
                "#section-final-logo",
                {
                    opacity: 1,
                    duration: 1,
                },
                5,
            )
            .to(
                "#section-final-cta",
                {
                    opacity: 1,
                    duration: 1,
                },
                8,
            );

        loadVideo(video, (video) => {
            tl.to(
                video,
                { currentTime: video.duration, duration: 8, ease: "none" },
                1,
            );
        });
    });
</script>
