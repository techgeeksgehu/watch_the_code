---
import Image from "@/components/helpers/Image.astro";
import LogoImage from "@/assets/images/logo.png";
import GEHU from "@/assets/images/gehu_hld_mono.svg";
import TechGeeks from "@/assets/images/tech_geeks_mono.svg";
---

<section id="section-final" class="relative bg-[#1b72d2]">
    <div class="absolute h-full w-full flex-center" id="section-final-pre-text">
        <h2
            class="font-sans text-white text-center text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        >
            Tech Geeks GEHU<br />presents
        </h2>
    </div>
    <video
        id="section-final-video"
        preload="auto"
        playsinline
        muted
        class="absolute inset-0 h-full w-full object-cover"
        style="object-position: 75% 50%"
    >
        <source
            src="/media/bg-480.mp4"
            media="(max-width: 480px)"
            type="video/mp4"
        />

        <source
            src="/media/bg-720.mp4"
            media="(min-width: 481px) and (max-width: 768px)"
            type="video/mp4"
        />
        <source
            src="/media/bg-1080.mp4"
            media="(min-width: 769px)"
            type="video/mp4"
        />
    </video>

    <div class="pointer-events-none absolute inset-0 z-10">
        <div
            id="section-final-logo"
            class="absolute top-1/2 left-1/2 md:left-1/3 lg:left-1/4 -translate-x-1/2 -translate-y-1/2"
        >
            <Image
                src={LogoImage}
                alt="Watch The Code Logo"
                class="w-100 xs:w-110 sm:w-115 md:w-120 lg:w-125 xl:w-150 h-auto"
            />
        </div>

        <div
            id="section-final-header"
            class="flex flex-row justify-between p-5"
        >
            <GEHU class="logo w-auto h-8 xs:h-16 sm:h-20 md:h-24 lg:h-28" />
            <TechGeeks
                class="logo w-auto h-8 xs:h-16 sm:h-20 md:h-24 lg:h-28"
            />
        </div>
    </div>
</section>

<script>
    const video = document.getElementById(
        "section-final-video",
    ) as HTMLVideoElement | null;

    document.addEventListener("DOMContentLoaded", () => {
        if (!video) return;

        gsap.set("#section-final", { opacity: 0, marginTop: "-100vh" });
        gsap.set(video, { currentTime: 0, opacity: 0 });
        gsap.set("#section-final-pre-text", { opacity: 0 });
        gsap.set("#section-final-logo", { opacity: 0 });
        gsap.set("#section-final-header .logo", { opacity: 0 });

        const tl = gsap.timeline({
            defaults: { duration: 1 },
            scrollTrigger: {
                trigger: "#section-final",
                start: "top top",
                end: "+=300% top",
                scrub: true,
                pin: true,
            },
        });

        tl.to("#section-final", { opacity: 1, duration: 0.5, ease: "none" }, 0)
            .to(
                "#section-final-pre-text",
                { opacity: 1, duration: 0.5, ease: "none" },
                0.1,
            )
            .to(
                "#section-final-pre-text",
                { scale: 1.01, duration: 0.9, ease: "none" },
                0.1,
            )
            .to(
                "#section-final-pre-text",
                { opacity: 0, duration: 0.5, ease: "none" },
                1,
            )
            .to(
                video,
                {
                    opacity: 1,
                    duration: 1,
                },
                1,
            )
            .to(
                "#section-final-header .logo",
                {
                    opacity: 1,
                    duration: 1,
                    stagger: 1,
                },
                2,
            )
            .to(
                "#section-final-logo",
                {
                    opacity: 1,
                    duration: 1,
                },
                5,
            );

        const setupTimeline = () => {
            const duration = video.duration;
            tl.to(
                video,
                { currentTime: duration, duration: 8, ease: "none" },
                1,
            ).to("#section-final", { opacity: 0, duration: 0.5, ease: "none" });
        };

        if (video.readyState >= 1) {
            setupTimeline();
        } else {
            video.addEventListener("loadedmetadata", setupTimeline, {
                once: true,
            });
        }
    });
</script>
