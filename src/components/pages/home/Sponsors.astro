---
import Image from "@/components/helpers/Image.astro";
import PokemonCard from "@/components/widgets/PokemonCard.astro";
import { getCollection } from "astro:content";

const sponsors = await getCollection("sponsors");
sponsors.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    {
        sponsors.map((sponsor) => (
            <a
                href={sponsor.data.href}
                target="_blank"
                rel="noopener noreferrer"
                id={sponsor.id}
                class="group flex flex-col items-center gap-3 no-underline!"
            >
                <PokemonCard>
                    <Image
                        src={sponsor.data.image}
                        alt={sponsor.data.name}
                        class="w-full h-auto object-contain"
                    />
                </PokemonCard>
                <div class="text-center px-1">
                    <p class="font-minecraft text-sm md:text-base tracking-wide leading-snug opacity-80 group-hover:opacity-100 transition-opacity">
                        {sponsor.data.name}
                    </p>
                    {sponsor.data.title && (
                        <p class="font-minecraft text-xs tracking-wide opacity-50 group-hover:opacity-70 transition-opacity mt-0.5">
                            {sponsor.data.title}
                        </p>
                    )}
                </div>
            </a>
        ))
    }
</div>
