<div id="smooth-wrapper">
    <div id="smooth-content">
        <slot />
    </div>
</div>

<script>
    import { ScrollTrigger, ScrollSmoother } from "@/lib/gsap";

    ScrollSmoother.create({
        wrapper: "#smooth-wrapper",
        content: "#smooth-content",
        smooth: 1,
        smoothTouch: 0.05,
        effects: true,
        ease: "power1.out",
    });

    // Recalculate all ScrollTrigger positions after every resource
    // (images, fonts, video metadata) has finished loading. Without this,
    // later sections whose trigger offsets depend on the fully-laid-out
    // page may end up with wrong start/end values and never animate.
    window.addEventListener("load", () => {
        ScrollSmoother.get()?.scrollTrigger?.refresh();
        ScrollTrigger.refresh(true);
    });

    window.dispatchEvent(new CustomEvent("gsap:ready"));
</script>
